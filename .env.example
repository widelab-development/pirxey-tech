# Public site URL used by Astro for canonical URLs + sitemap. Override per
# deploy when previewing on a different host.
PUBLIC_SITE=https://pirxey.tech

# Mailcheck backend — powers the "Run deep VMC validation" button in the
# brief 002 (Why your emails go to spam) BIMI card. Leave unset and the
# button is hidden; the in-browser DNS audit still works without it.
# Production value lives in Cloudflare Pages → Settings → Environment vars.
PUBLIC_MAILCHECK_API_URL=https://mailcheck-827121668940.europe-central2.run.app
