---
import "@styles/global.css";
import SEO from "@components/SEO.astro";
import SpaceCanvas from "@components/react/SpaceCanvas.tsx";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
  author?: { name: string; url?: string };
  tags?: string[];
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}
const props = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <SEO {...props} />
</head>
<body>
  {/* Pixel-faithful port of pirxey.com's animated WebGL star field.
      Fixed at z-index -1, fills viewport, all dark sections show through. */}
  <SpaceCanvas client:only="react" />
  <slot />
</body>
</html>
