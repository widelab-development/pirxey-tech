---
import BaseLayout from "./BaseLayout.astro";
import TopBar from "@components/TopBar.astro";
import Hero from "@components/Hero.astro";
import Footer from "@components/Footer.astro";

interface NavItem { label: string; href: string; active?: boolean; }

interface MissionData {
  id: string; title: string; subtitle?: string; description: string;
  publishedAt: Date; updatedAt?: Date;
  author: { name: string; url?: string; role?: string };
  tags?: string[];
  heroImage?: string;
  heroEyebrow?: string;
  heroHeadline: string;
  heroSub: string;
  heroStats?: { value: string; label: string; tone?: "up" | "mid" | "down" }[];
}

interface Props {
  brief: MissionData;
  nav?: NavItem[];
  footerNote?: string;
}

const { brief, nav, footerNote = "" } = Astro.props;

// Reasonable defaults for an LP-style nav (consumers can override)
const navItems = nav ?? [
  { label: "Thesis", href: "#thesis", active: true },
  { label: "Cockpit", href: "#cockpit" },
  { label: "The Gap", href: "#solo" },
  { label: "Forces", href: "#forces" },
  { label: "Evidence", href: "#evidence" },
];

// Build JSON-LD TechArticle schema for SEO
const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://pirxey.tech";
const url = new URL(Astro.url.pathname, site).toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "TechArticle",
      "@id": `${url}#article`,
      headline: brief.title,
      alternativeHeadline: `Mission Brief ${brief.id}`,
      description: brief.description,
      image: brief.heroImage ? `${site}${brief.heroImage}` : `${site}/assets/hero-bg.png`,
      datePublished: brief.publishedAt.toISOString(),
      ...(brief.updatedAt && { dateModified: brief.updatedAt.toISOString() }),
      inLanguage: "en",
      keywords: (brief.tags ?? []).join(", "),
      author: {
        "@type": "Person",
        name: brief.author.name,
        ...(brief.author.role && { jobTitle: brief.author.role }),
        worksFor: { "@type": "Organization", name: "Pirxey" },
        ...(brief.author.url && { url: brief.author.url }),
      },
      publisher: {
        "@type": "Organization",
        name: "Pirxey",
        url: "https://pirxey.com",
        logo: { "@type": "ImageObject", url: `${site}/assets/pirxey-logo.svg` },
      },
      mainEntityOfPage: { "@type": "WebPage", "@id": url },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Pirxey", item: "https://pirxey.com" },
        { "@type": "ListItem", position: 2, name: "Mission Briefs", item: site },
        { "@type": "ListItem", position: 3, name: `${brief.id} · ${brief.title}` },
      ],
    },
  ],
};
---

<BaseLayout
  title={`Mission Brief ${brief.id} — ${brief.title} | Pirxey`}
  description={brief.description}
  image={brief.heroImage ?? "/assets/hero-bg.png"}
  type="article"
  publishedAt={brief.publishedAt}
  updatedAt={brief.updatedAt}
  author={{ name: brief.author.name, url: brief.author.url }}
  tags={brief.tags}
  jsonLd={jsonLd}
>
  <TopBar
    mission={{ label: "Mission Brief", id: brief.id, title: brief.title }}
    nav={navItems}
  />

  <Hero
    missionId={brief.id}
    publishedAt={brief.publishedAt}
    author={brief.author.name}
    headlineHtml={brief.heroHeadline}
    sub={brief.heroSub}
    stats={brief.heroStats}
    background={brief.heroImage}
  />

  <slot />

  <Footer note={footerNote} />
</BaseLayout>
