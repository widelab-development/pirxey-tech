---
/**
 * /  — Marketing homepage.
 * Faithful port from pirxey-website-nextjs Sanity blocks → Astro React islands.
 * Section order matches Figma "🎨 Pirxey - Homepage" canvas (1:50):
 *   Hero → Clients → Features (How we help) → Technologies → SplitImage v1 →
 *   Clients v2 → FeaturesLight v2 → Footer
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import { HeroMain } from "../components/sections/hero-main/index.tsx";
import { Clients } from "../components/sections/clients/index.tsx";
import { Features } from "../components/sections/features/index.tsx";
import { Technologies } from "../components/sections/technologies/index.tsx";
import { SplitImage } from "../components/sections/split-image/index.tsx";
import { FeaturesLight } from "../components/sections/features-light/index.tsx";
import clientsData from "../data/clients.json";
import servicesData from "../data/services.json";

const locale = "en";

// Map clients.json → Clients component shape. ClientType heuristic until real data lands.
const clientItems = clientsData.clients.map((c, i) => ({
  key: c.slug,
  name: c.name,
  clientType: (i % 3 === 0 ? "Enterprise" : i % 3 === 1 ? "Scale-up" : "Start-up") as "Enterprise" | "Scale-up" | "Start-up",
  projectType: ["Web platform","Mobile app","AI tooling","Data pipeline","E-commerce","DevOps"][i % 6],
  websiteUrl: c.url,
  logo: c.logo,
}));

// Services from services.json → Features feature items (for "Here's how we can help you")
const featureItems = servicesData.services
  .slice()
  .sort((a, b) => a.order - b.order)
  .map((s) => ({
    key: s.slug,
    title: s.translations.en.title,
    text: s.translations.en.tagline,
    href: `/services/${s.slug}/`,
  }));

// Technologies — use existing data shape (slug+name+logo per item, but tech grid wants flat)
import technologiesData from "../data/technologies.json";
const techItems = technologiesData.groups.flatMap((g) =>
  g.items.map((t) => ({ key: `${g.label}-${t.slug}`, name: t.name, icon: t.logo }))
);

// FeaturesLight for "What makes Pirxey special"
const specialFeatures = [
  {
    key: "make-sense",
    titleStart: "Make-sense",
    titleEnd: "policy.",
    description: "Less process, more thinking. Optimal decisions, not political ones.",
    image: "/assets/images/area-moon.webp",
  },
  {
    key: "senior-access",
    titleStart: "Direct access",
    titleEnd: "to seniors.",
    description: "Your Slack has a senior engineer, not an account manager.",
    image: "/assets/images/astronaut-on-moon.png",
  },
  {
    key: "transparency",
    titleStart: "End-to-end",
    titleEnd: "transparency.",
    description: "Daily status, weekly demo, open burn-down. No surprises.",
    image: "/assets/images/two-astronauts-on-moon.webp",
  },
];

// SplitImage sections — "Velocity without chaos."
const splitSections = [
  {
    key: "judgment",
    title: "Senior engineering judgment, AI-assisted velocity.",
    text: "Architects and seniors decide trade-offs. AI handles the boilerplate. You ship 3-5× faster without quality regression.",
    image: "/assets/images/area-astronaut.webp",
  },
  {
    key: "sprints",
    title: "AI-Sprint delivery — outcomes, not hours.",
    text: "8-week sprints with clear milestones. You pay for results. No hourly billing roulette, no surprise overrun.",
    image: "/assets/images/area-moon.webp",
  },
  {
    key: "talent",
    title: "Talent density: 130+ engineers in the network.",
    text: "We match the project to the talent, not the talent to availability. Senior-heavy by design, with juniors mentored not parked.",
    image: "/assets/images/two-astronauts-on-moon.webp",
  },
];
---

<BaseLayout
  title="Pirxey — AI-Native software development for serious teams"
  description="Pirxey delivers production-ready software at AI speed. Senior engineers + autonomous AI agents. MVPs, full-scale systems, and AI integrations across the US, Israel and Europe."
  type="website"
>
  <main class="space-y-section-padding">
    <HeroMain
      stickerText="Engineering with AI velocity"
      title="Ship production-ready software at AI speed."
      text="We combine senior engineers with autonomous AI agents — Claude, Codex, Copilot — to turn complex ideas into clean, scalable code. No SaaS lock-in. No hourly billing roulette."
      links={[
        { key: "primary", text: "Let's talk", href: "mailto:sales@pirxey.com", variant: "default" },
        { key: "secondary", text: "See services", href: "/services/", variant: "inverted" },
      ]}
      client:load
    />

    <Clients
      title="We developed software for"
      clients={clientItems}
      stickerText="20+ missions accomplished"
      cta={{ text: "See our work", href: "/blog/" }}
      client:load
    />

    <Features
      eyebrow="Mission profiles"
      title="Here's how we can help you."
      features={featureItems}
      cta={{ text: "All services", href: "/services/" }}
      client:visible
    />

    <Technologies
      eyebrow="Stack"
      title="Technologies we use."
      technologies={techItems}
      client:visible
    />

    <SplitImage
      title="Velocity without chaos."
      sections={splitSections}
      startingOrientation="imageRight"
      cta={{ text: "Talk to a senior", href: "mailto:sales@pirxey.com" }}
      client:visible
    />

    <FeaturesLight
      title="What makes Pirxey special."
      features={specialFeatures}
      stickerText="Engineering we're not afraid to show the client"
      cta={{ text: "Start a project", href: "mailto:sales@pirxey.com" }}
      client:visible
    />
  </main>
</BaseLayout>
