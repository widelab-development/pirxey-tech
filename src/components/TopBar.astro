---
/**
 * TopBar — Pirxey header. Logo on the left, optional mission identifier,
 * inline nav on the right. Matches the Figma "Header" component (5:566).
 */
interface NavItem { label: string; href: string; active?: boolean; back?: boolean; }

interface Props {
  mission?: { label: string; id: string; title: string } | null;
  nav?: NavItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  mission = null,
  nav = [],
  ctaLabel = "Let's talk",
  ctaHref = "#cta",
} = Astro.props;
---

<header class="topbar" id="topbar">
  <div class="brand">
    <a class="logo" href="https://pirxey.com" target="_blank" rel="noopener" aria-label="Pirxey homepage">
      <img src="/assets/pirxey-logo.svg" alt="Pirxey" width="151" height="40" />
    </a>
    {mission && (
      <>
        <span class="bar" aria-hidden="true"></span>
        <a class="mission" href="/" aria-label="Back to Mission Briefs index">
          <span class="marker" aria-hidden="true"></span>
          <span class="label">{mission.label}</span>
          <span class="id">{mission.id}</span>
          <span class="sep" aria-hidden="true">/</span>
          <span class="title">{mission.title}</span>
        </a>
      </>
    )}
  </div>

  <nav aria-label="Page sections">
    {nav.map(item => (
      <a href={item.href} class:list={[item.back && "back"]}>
        {item.active && <span class="active-dot" aria-hidden="true"></span>}
        {item.label}
      </a>
    ))}
    <a href={ctaHref} class="talk">{ctaLabel}
      <svg viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M0 26.73h42.29L32.23 37.85 35.08 41l13.71-15.16c.69-.76.69-1.92 0-2.68L35.08 8l-2.85 3.15 10.06 11.13H0v4.45z" fill="#FF6026"/>
      </svg>
    </a>
  </nav>
</header>

<script>
  // Toggle background on scroll for sticky readability.
  const tb = document.getElementById("topbar");
  if (tb) {
    const onScroll = () => tb.classList.toggle("is-stuck", window.scrollY > 120);
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>

<style>
  .topbar {
    position: absolute; top: 0; left: 0; right: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 80px; height: 72px;
    pointer-events: none;
  }
  .topbar > * { pointer-events: auto; }
  .topbar.is-stuck {
    position: fixed;
    background: rgba(6, 4, 17, 0.78);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    animation: dropin 0.25s var(--ease-out);
  }
  @keyframes dropin { from { transform: translateY(-100%); } to { transform: translateY(0); } }

  .brand { display: inline-flex; align-items: center; gap: 18px; height: 40px; }
  .logo { display: inline-flex; align-items: center; height: 40px; text-decoration: none; color: var(--on-dark); }
  .logo:hover { opacity: 0.85; }
  .logo img { height: 40px; width: auto; }
  .brand .bar { height: 28px; width: 1px; background: rgba(249, 249, 234, 0.22); display: block; }

  .mission { display: inline-flex; align-items: baseline; gap: 10px; line-height: 1; font-family: var(--font-sans); text-decoration: none; color: inherit; transition: opacity 0.15s; }
  a.mission:hover { opacity: 0.78; }
  a.mission:hover .title { color: var(--orange); }
  .mission .marker {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--orange); box-shadow: 0 0 10px var(--orange);
    animation: beacon 2s ease-in-out infinite; align-self: center;
  }
  .mission .label { font-weight: 700; font-size: 13px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--orange); }
  .mission .id { font-weight: 700; font-size: 13px; letter-spacing: 0.06em; color: var(--on-dark-2); font-variant-numeric: tabular-nums; }
  .mission .sep { color: var(--on-dark-3); font-weight: 500; font-size: 13px; }
  .mission .title { font-family: var(--font-body); font-style: italic; font-weight: 500; font-size: 15px; color: var(--on-dark); letter-spacing: -0.005em; max-width: 380px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  nav {
    display: flex; align-items: center; gap: 32px;
    font-family: var(--font-sans); font-weight: 700; font-size: 16px; line-height: 1.3;
  }
  nav a { display: inline-flex; align-items: center; gap: 8px; color: var(--on-dark); text-decoration: none; transition: opacity 0.15s; }
  nav a:hover { opacity: 0.75; }
  nav .active-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--on-dark); }
  nav a.back { color: var(--on-dark-2); font-weight: 500; padding-right: 12px; border-right: 1px solid var(--line-dark-2); }
  nav a.back:hover { color: var(--orange); opacity: 1; }
  nav a.talk { color: var(--orange); }
  nav a.talk:hover { color: var(--orange-hover); opacity: 1; }
  nav a.talk svg { width: 21px; height: 21px; margin-left: 8px; transition: transform 0.2s; }
  nav a.talk:hover svg { transform: translateX(3px); }

  @media (max-width: 1280px) { .mission .title { max-width: 220px; } }
  @media (max-width: 1100px) { .mission .title, .mission .sep { display: none; } nav { gap: 24px; font-size: 15px; } }
  @media (max-width: 760px) {
    .topbar { padding: 14px 20px; }
    .brand .bar, .mission { display: none; }
    nav a:not(.talk):not(.back) { display: none; }
  }
</style>
