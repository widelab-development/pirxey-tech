---
interface Props { note?: string; }
const { note = "" } = Astro.props;
---
<footer class="footer">
  <div>Pirxey © 2026 · <a href="https://pirxey.com" target="_blank" rel="noopener">Develop &amp; Prosper.</a></div>
  {note && <div class="right" set:html={note} />}
</footer>
<style>
  .footer {
    padding: 48px 88px 40px;
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--font-sans); font-size: 12px; color: var(--on-dark-3);
    border-top: 1px solid var(--line-dark); gap: 24px; flex-wrap: wrap;
  }
  .footer a { color: var(--on-dark-2); text-decoration: none; }
  .footer a:hover { color: var(--orange); }
  .footer .right { max-width: 680px; text-align: right; letter-spacing: 0.02em; }
  @media (max-width: 760px) { .footer { padding: 32px 24px; flex-direction: column; } .footer .right { text-align: left; } }
</style>
