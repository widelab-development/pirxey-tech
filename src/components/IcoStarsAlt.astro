---
/**
 * Pirxey sparkle marker — four four-pointed stars in a horizontal row.
 * Path byte-for-byte from pirxey.com's ico-stars.svg (78×34 viewBox).
 */
interface Props { size?: number; class?: string; }
const { size = 78, class: className } = Astro.props;
const height = size * (34 / 78);
