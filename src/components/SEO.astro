---
/**
 * SEO — single source of head metadata for a page.
 * Pass either a brief frontmatter or a plain { title, description, image, type }.
 */
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
  author?: { name: string; url?: string };
  tags?: string[];
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}

const {
  title, description,
  image = "/assets/hero-bg.png",
  type = "website",
  publishedAt, updatedAt, author,
  tags = [],
  jsonLd,
  noindex = false,
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://pirxey.tech";
const canonical = new URL(Astro.url.pathname, site).toString();
const imageAbs = image.startsWith("http") ? image : `${site}${image}`;
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#060411" />
<meta name="color-scheme" content="dark" />
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/svg+xml" href="/assets/ico-stars-alt.svg" />
{noindex
  ? <meta name="robots" content="noindex,nofollow" />
  : <meta name="robots" content="index,follow,max-image-preview:large" />}

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Pirxey · Mission Briefs" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageAbs} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />
{type === "article" && publishedAt && (
  <meta property="article:published_time" content={publishedAt.toISOString()} />
)}
{type === "article" && updatedAt && (
  <meta property="article:modified_time" content={updatedAt.toISOString()} />
)}
{type === "article" && author?.url && (
  <meta property="article:author" content={author.url} />
)}
{type === "article" && tags.map(t => <meta property="article:tag" content={t} />)}

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageAbs} />

{/* Fonts (preconnect + import) */}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Fira+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

{jsonLd && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
