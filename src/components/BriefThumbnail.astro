---
/**
 * BriefThumbnail — abstract preview shape shown next to a Mission Brief on
 * the homepage. Lives in two roles: as the big preview next to the featured
 * card, and as the smaller right-side preview in archive cards.
 *
 * The shape is driven by the brief's `previewKind` frontmatter so each brief
 * gets its own visual idiom — the AI-decay curve was specific to brief 001;
 * an email/auth brief shouldn't inherit it.
 */
interface Props {
  /** Brief id, used to scope gradient IDs so multiple thumbnails can coexist on one page. */
  id: string;
  kind: "curve" | "envelope" | "shield";
  /** Two short labels overlaid on the shape (e.g. start/end stats). */
  labels?: [string, string];
  /** Visual size — `lg` for the featured card, `sm` for archive list rows. */
  size?: "lg" | "sm";
}

const { id, kind, labels = ["", ""], size = "lg" } = Astro.props;
const uid = `bt-${id}-${kind}`;
---

<div class:list={["brief-thumb", `brief-thumb--${size}`, `brief-thumb--${kind}`]} aria-hidden="true">
  <div class="bt-grid"></div>
  <div class="bt-art">
    {kind === "curve" && (
      <svg viewBox="0 0 320 200" preserveAspectRatio="none">
        <defs>
          <linearGradient id={`${uid}-fill`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#FF6026" stop-opacity="0.5" />
            <stop offset="100%" stop-color="#FF6026" stop-opacity="0" />
          </linearGradient>
          <linearGradient id={`${uid}-stroke`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#FFB46B" />
            <stop offset="100%" stop-color="#FF6026" />
          </linearGradient>
        </defs>
        <path d="M0 20 C 60 30, 120 80, 180 120 S 280 175, 320 185"
              fill="none" stroke={`url(#${uid}-stroke)`} stroke-width="3" />
        <path d="M0 20 C 60 30, 120 80, 180 120 S 280 175, 320 185 L 320 200 L 0 200 Z"
              fill={`url(#${uid}-fill)`} />
        <circle cx="32" cy="22" r="4" fill="#F9F9EA" opacity="0.6" />
        <circle cx="288" cy="183" r="4" fill="#F9F9EA" opacity="0.6" />
      </svg>
    )}

    {kind === "envelope" && (
      <svg viewBox="0 0 320 200" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id={`${uid}-stripe`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#FFB46B" />
            <stop offset="100%" stop-color="#FF6026" />
          </linearGradient>
        </defs>
        {/* envelope body */}
        <rect x="36" y="44" width="248" height="124" rx="6"
              fill="rgba(255,96,38,0.05)" stroke="#FF6026" stroke-width="1.3" stroke-opacity="0.55" />
        {/* envelope fold ghost — drawn behind, opacity'd so it reads as fold, not occluding the stripes */}
        <path d="M36 56 L160 124 L284 56" fill="none" stroke="#FF6026" stroke-width="1" stroke-opacity="0.18" />
        {/* four protocol stripes — narrow rounded bars stacked inside */}
        <g>
          <rect x="60" y="76"  width="170" height="12" rx="6" fill={`url(#${uid}-stripe)`} opacity="0.95" />
          <rect x="60" y="96"  width="200" height="12" rx="6" fill="#FF6026" opacity="0.78" />
          <rect x="60" y="116" width="140" height="12" rx="6" fill="#FF6026" opacity="0.6" />
          <rect x="60" y="136" width="180" height="12" rx="6" fill="#FF6026" opacity="0.42" />
        </g>
        {/* tiny labels next to stripes */}
        <text x="240" y="86"  class="bt-stripe-label">SPF</text>
        <text x="270" y="106" class="bt-stripe-label">DKIM</text>
        <text x="210" y="126" class="bt-stripe-label">DMARC</text>
        <text x="250" y="146" class="bt-stripe-label">BIMI</text>
        {/* check dot top-right */}
        <circle cx="284" cy="44" r="6" fill="#FF6026" />
        <path d="M281 44 L284 47 L289 41" fill="none" stroke="#060411" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )}

    {kind === "shield" && (
      <svg viewBox="0 0 320 200" preserveAspectRatio="xMidYMid meet">
        <defs>
          <linearGradient id={`${uid}-fill`} x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#FF6026" stop-opacity="0.35" />
            <stop offset="100%" stop-color="#FF6026" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path d="M160 28 L228 50 V104 Q228 150 160 174 Q92 150 92 104 V50 Z"
              fill={`url(#${uid}-fill)`} stroke="#FF6026" stroke-width="1.4" stroke-opacity="0.7" />
        <path d="M132 104 L154 124 L194 78" fill="none" stroke="#FFB46B" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )}
  </div>

  {labels[0] && <span class="bt-ann bt-ann-l">{labels[0]}</span>}
  {labels[1] && <span class="bt-ann bt-ann-r">{labels[1]}</span>}
</div>

<style>
  .brief-thumb {
    width: 100%; aspect-ratio: 8 / 5;
    background: rgba(6, 4, 17, 0.6);
    border: 1px solid var(--line-dark-2);
    border-radius: 12px;
    position: relative; overflow: hidden;
    box-shadow: 0 16px 40px -16px rgba(255, 96, 38, 0.32);
  }
  .brief-thumb--sm {
    box-shadow: 0 10px 28px -14px rgba(255, 96, 38, 0.28);
    aspect-ratio: 16 / 10;
  }

  .bt-grid {
    position: absolute; inset: 16px;
    background-image:
      linear-gradient(rgba(249, 249, 234, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249, 249, 234, 0.05) 1px, transparent 1px);
    background-size: 28px 22px;
  }
  .brief-thumb--sm .bt-grid { inset: 10px; background-size: 22px 18px; }

  .bt-art { position: absolute; inset: 16px; }
  .brief-thumb--sm .bt-art { inset: 10px; }
  .bt-art svg { width: 100%; height: 100%; display: block; }

  .bt-ann {
    position: absolute;
    font-family: var(--font-sans);
    font-size: 11px; font-weight: 700;
    padding: 3px 8px; border-radius: 999px;
    background: rgba(6, 4, 17, 0.85);
    border: 1px solid var(--line-dark-2);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .bt-ann-l { top: 8px; left: 28px; color: var(--amber); }
  .bt-ann-r { bottom: 8px; right: 28px; color: var(--orange); }
  .brief-thumb--sm .bt-ann { font-size: 9.5px; padding: 2px 6px; }
  .brief-thumb--sm .bt-ann-l { top: 6px; left: 18px; }
  .brief-thumb--sm .bt-ann-r { bottom: 6px; right: 18px; }

  /* Envelope-kind label text inside SVG (rendered through <text>) — needs to
     pick up the page font family + a muted cream color. */
  :global(.bt-stripe-label) {
    font-family: var(--font-mono);
    font-size: 8px;
    fill: rgba(249, 249, 234, 0.6);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 700;
  }
</style>
