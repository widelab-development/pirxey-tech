---
interface Props { stat: string; headline: string; body: string; source: string; url: string; }
const { stat, headline, body, source, url } = Astro.props;
---
<a class="evi-card" href={url} target="_blank" rel="noopener noreferrer">
  <div class="stat">{stat}</div>
  <div class="headline">{headline}</div>
  <div class="body">{body}</div>
  <div class="source">
    <span>{source}</span>
    <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 9l6-6M5 3h4v4" stroke="currentColor" stroke-width="1.3" fill="none"/></svg>
  </div>
</a>
<style>
  .evi-card {
    display: flex; flex-direction: column; gap: 14px;
    background: #fff; border: 1px solid var(--line-light); border-radius: 16px;
    padding: 32px; text-decoration: none; color: var(--on-light);
    transition: border-color 0.2s, transform 0.2s;
  }
  .evi-card:hover { border-color: var(--orange); transform: translateY(-2px); }
  .stat { font-family: var(--font-sans); font-size: 56px; line-height: 1; color: var(--orange-overlay); font-weight: 700; letter-spacing: -0.03em; }
  .headline { font-family: var(--font-sans); font-size: 22px; line-height: 1.25; font-weight: 700; letter-spacing: -0.01em; }
  .body { color: var(--on-light-2); font-size: 14px; line-height: 1.55; flex: 1; }
  .source {
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
    font-family: var(--font-sans); font-size: 11px; color: var(--on-light-2);
    border-top: 1px dashed var(--line-light); padding-top: 14px; letter-spacing: 0.04em;
  }
</style>
