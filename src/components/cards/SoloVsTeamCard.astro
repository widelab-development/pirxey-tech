---
interface Props {
  n: string;
  title: string;
  /** HTML allowed (e.g. <code>) */
  titleHtml?: string;
  solo: string;
  team: string;
  /** HTML allowed for em / strong */
  punch: string;
}
const { n, title, titleHtml, solo, team, punch } = Astro.props;
---
<article class="solo-card">
  <div class="head">
    <span class="num">{n}</span>
    <span class="pill solo">Solo</span>
    <span class="pill team">Team</span>
  </div>
  {titleHtml ? <h3 set:html={titleHtml} /> : <h3>{title}</h3>}
  <div class="vs">
    <div class="col"><strong>Solo</strong>{solo}</div>
    <div class="arrow" aria-hidden="true">→</div>
    <div class="col" set:html={`<strong>Team</strong>${team}`} />
  </div>
  <div class="punch" set:html={punch} />
</article>

<style>
  .solo-card {
    background: #fff; border: 1px solid var(--line-light); border-radius: 16px;
    padding: 32px; display: flex; flex-direction: column; gap: 14px;
    position: relative; overflow: hidden;
  }
  .head { display: flex; align-items: center; gap: 14px; font-family: var(--font-sans); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; }
  .head .num { color: var(--on-light-2); }
  .pill { padding: 4px 10px; border-radius: var(--radius-pill); font-size: 10px; letter-spacing: 0.08em; }
  .pill.solo { background: rgba(54, 152, 250, 0.10); color: var(--blue-deep); }
  .pill.team { background: rgba(255, 96, 38, 0.10); color: var(--orange-overlay); }
  h3 { font-family: var(--font-sans); font-size: 24px; line-height: 1.2; font-weight: 700; letter-spacing: -0.01em; margin: 0; }
  h3 :global(code) { font-family: var(--font-mono); font-size: 0.8em; }
  .vs { display: grid; grid-template-columns: 1fr auto 1fr; gap: 14px; align-items: start; margin-top: 8px; }
  .vs .col { font-size: 14px; line-height: 1.5; color: var(--on-light); }
  .vs .col strong { font-family: var(--font-sans); font-size: 11px; color: var(--on-light-2); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; display: block; margin-bottom: 6px; }
  .vs .col :global(em) { font-style: normal; color: var(--orange-overlay); font-weight: 600; }
  .arrow { font-family: var(--font-sans); color: var(--on-light-3); font-size: 24px; display: flex; align-items: center; font-weight: 600; }
  .punch {
    margin-top: 6px; padding-top: 14px; border-top: 1px dashed var(--line-light);
    font-family: var(--font-sans); font-size: 13px; line-height: 1.5;
    color: var(--on-light); font-weight: 500;
  }
  .punch :global(em) { font-style: normal; color: var(--orange-overlay); font-weight: 600; }
  @media (max-width: 760px) {
    .vs { grid-template-columns: 1fr; gap: 8px; }
    .arrow { display: none; }
  }
</style>
